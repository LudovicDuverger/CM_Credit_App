{
  "name": "cm-credit-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --experimental-strip-types server.ts",
    "dev": "node --watch --experimental-strip-types server.ts",
    "start:tsx": "tsx server.ts",
    "dev:tsx": "tsx watch server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --configLoader native --pool threads",
    "verify": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@uipath/uipath-typescript": "^1.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
